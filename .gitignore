# ─────────────────────────────────────────────────────────────
# PlantDoc Live Demo — .gitignore
# ─────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
.conda/

# Environment variables
.env
.env.*
!.env.example

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Docker override files (keep docker-compose.yml, ignore local overrides)
docker-compose.override.yml

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Large model files — commit best.onnx explicitly if needed
# Uncomment the next line if your model is >100MB and you use Git LFS instead:
# assets/*.onnx
